// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Connection URLs are configured in prisma.config.ts via the NeonDB adapter.
  provider = "postgresql"
}

model ForecastIOT {
  id          Int      @id @default(autoincrement())
  temperature Float
  humidity    Float
  createdAt   DateTime @default(now())

  @@map("forecast_iot")
}
